              "raw": "{{baseUrl}}/notas-debito",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "notas-debito"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"facturaId\": \"{{facturaId}}\",\n  \"serieId\": \"{{serieNotaDebitoId}}\",\n  \"monto\": 10,\n  \"razon\": \"Flete adicional no cobrado\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('ND emitida', () => pm.expect(pm.response.code).to.eql(201));"
                ]
              }
            }
          ]
        },
        {
          "name": "Saldar factura (pago final $60)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/facturas/{{facturaId}}/pagos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "facturas",
                "{{facturaId}}",
                "pagos"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"monto\": 60,\n  \"metodo\": \"EFECTIVO\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
