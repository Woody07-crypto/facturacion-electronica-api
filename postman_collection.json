              }
            ],
            "url": {
              "raw": "{{baseUrl}}/facturas/{{facturaId}}/pagos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "facturas",
                "{{facturaId}}",
                "pagos"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"monto\": 50,\n  \"metodo\": \"TRANSFERENCIA\",\n  \"referencia\": \"REF-001\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Estado PAGADA_PARCIAL', () => pm.expect(pm.response.json().estado).to.eql('PAGADA_PARCIAL'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Intento de pago mayor al saldo (debe fallar 400)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/facturas/{{facturaId}}/pagos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "facturas",
                "{{facturaId}}",
                "pagos"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"monto\": 9999,\n  \"metodo\": \"EFECTIVO\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Rechazado 400', () => pm.expect(pm.response.code).to.eql(400));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "05 · Notas de crédito y débito",
      "item": [
