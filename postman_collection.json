    {
      "name": "08 · Emisor (DTE Fase 1)",
      "item": [
        {
          "name": "Registrar emisor (ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/emisor", "host": ["{{baseUrl}}"], "path": ["emisor"] },
