              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "notas-credito"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"facturaId\": \"{{facturaId}}\",\n  \"serieId\": \"{{serieNotaId}}\",\n  \"monto\": 29.95,\n  \"razon\": \"Devolución de mercadería\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('NC emitida', () => pm.expect(pm.response.code).to.eql(201));"
                ]
              }
            }
          ]
        },
        {
          "name": "Emitir ND válida ($10) — aumenta saldo",
