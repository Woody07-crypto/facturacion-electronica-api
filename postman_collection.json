{
  "info": {
    "name": "Plataforma de Facturación Electrónica",
    "description": "Flujo completo: registro → login → cliente → series → emisión → pago → nota de crédito → nota de débito → anulación → conciliación → reportes → bitácora. Ejecutar en orden.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "clienteId",
      "value": ""
    },
    {
      "key": "serieFacturaId",
      "value": ""
    },
    {
      "key": "serieNotaId",
      "value": ""
    },
    {
      "key": "serieNotaDebitoId",
      "value": ""
    },
    {
      "key": "facturaId",
      "value": ""
    },
    {
      "key": "facturaAnulableId",
      "value": ""
    },
    {
      "key": "emisorId",
      "value": ""
    },
    {
      "key": "establecimientoId",
      "value": ""
    },
    {
      "key": "puntoVentaId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 · Autenticación",
      "item": [
        {
          "name": "Registrar usuario (primero = ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@esen.com.sv\",\n  \"password\": \"Secreto123\",\n  \"nombre\": \"Administrador ESEN\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Usuario creado', () => pm.expect(pm.response.code).to.be.oneOf([201, 409]));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@esen.com.sv\",\n  \"password\": \"Secreto123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json();",
                  "pm.collectionVariables.set('token', r.access_token);",
                  "pm.test('Token recibido', () => pm.expect(r.access_token).to.be.a('string'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
