          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) pm.collectionVariables.set('serieNotaDebitoId', pm.response.json().id);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03 · Emisión",
      "item": [
        {
          "name": "Emitir factura (IVA 13% automático)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/facturas",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "facturas"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clienteId\": \"{{clienteId}}\",\n  \"serieId\": \"{{serieFacturaId}}\",\n  \"diasCredito\": 30,\n  \"lineas\": [\n    {\n      \"descripcion\": \"Taladro percutor INGCO 850W\",\n      \"cantidad\": 2,\n      \"precioUnitario\": 50\n    },\n    {\n      \"descripcion\": \"Disco de corte PFERD 4.5\\\"\",\n      \"cantidad\": 10,\n      \"precioUnitario\": 1.5\n    }\n  ]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const f = pm.response.json();",
                  "pm.collectionVariables.set('facturaId', f.id);",
                  "pm.test('Total con IVA correcto', () => pm.expect(f.total).to.eql(129.95));"
                ]
              }
            }
          ]
        },
        {
          "name": "Emitir segunda factura (para anular)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/facturas",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "facturas"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clienteId\": \"{{clienteId}}\",\n  \"serieId\": \"{{serieFacturaId}}\",\n  \"lineas\": [\n    {\n      \"descripcion\": \"Pintura ECO PAINT galón\",\n      \"cantidad\": 1,\n      \"precioUnitario\": 20\n    }\n  ]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('facturaAnulableId', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Consultar factura",
          "request": {
            "method": "GET",
            "header": [
