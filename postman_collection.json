            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Constructora Salvadoreña S.A. de C.V.\",\n  \"nit\": \"0614-123456-101-2\",\n  \"nrc\": \"123456-7\",\n  \"giro\": \"Construcción\",\n  \"direccion\": \"San Salvador\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) pm.collectionVariables.set('clienteId', pm.response.json().id);",
                  "pm.test('Cliente listo', () => pm.expect(pm.response.code).to.be.oneOf([201, 409]));"
                ]
              }
            }
          ]
        },
