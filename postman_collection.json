                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/facturas/{{facturaId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "facturas",
                "{{facturaId}}"
              ]
            }
          }
        },
        {
          "name": "Consultar saldo pendiente",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
